[
  {
    "class_type": "AgentWorkflow",
    "category": "Agentic",
    "display_name": "调用工作流",
    "description": "Agentic 组合：引用已保存的工作流。可展开查看由原子化元件组成的内部结构。",
    "color": "#4a3060",
    "inputs": [
      {
        "name": "input",
        "type": "any"
      }
    ],
    "outputs": [
      {
        "name": "output",
        "type": "any"
      }
    ],
    "params": {
      "role_declaration": {
        "type": "object",
        "label": "角色声明",
        "fields": {
          "role": {
            "type": "select",
            "options": [
              "master",
              "slave",
              "peer"
            ],
            "default": "slave",
            "label": "角色"
          },
          "responsibility": {
            "type": "text",
            "default": "",
            "label": "职责"
          },
          "constraints": {
            "type": "text",
            "default": "",
            "label": "约束"
          },
          "consumers": {
            "type": "text",
            "default": "",
            "label": "消费者"
          }
        }
      },
      "workflow_id": {
        "type": "string",
        "default": "",
        "label": "工作流 ID"
      },
      "workflow_name": {
        "type": "string",
        "default": "",
        "label": "工作流名称"
      },
      "expandable": {
        "type": "boolean",
        "default": true,
        "label": "可展开"
      }
    }
  },
  {
    "class_type": "AgenticUnit",
    "category": "Agentic",
    "display_name": "Agentic 单元",
    "description": "Agentic 组合：工作层(LLM调用) + 核验层(正则匹配) + 重试循环。由原子化元件组成，可展开查看内部结构。",
    "color": "#5a2070",
    "inputs": [
      {
        "name": "task_input",
        "type": "any"
      },
      {
        "name": "purpose",
        "type": "string"
      },
      {
        "name": "expected_pattern",
        "type": "string"
      },
      {
        "name": "prior_knowledge",
        "type": "string",
        "optional": true
      }
    ],
    "outputs": [
      {
        "name": "verified_output",
        "type": "any"
      },
      {
        "name": "validation_report",
        "type": "object"
      }
    ],
    "params": {
      "role_declaration": {
        "type": "object",
        "label": "角色声明",
        "fields": {
          "role": {
            "type": "select",
            "options": [
              "master",
              "slave",
              "peer"
            ],
            "default": "slave",
            "label": "角色"
          },
          "responsibility": {
            "type": "text",
            "default": "",
            "label": "职责"
          },
          "constraints": {
            "type": "text",
            "default": "",
            "label": "约束"
          },
          "consumers": {
            "type": "text",
            "default": "",
            "label": "消费者"
          }
        }
      },
      "work_model": {
        "type": "select",
        "default": "GLM-5.1",
        "options": [
          "GLM-5.1",
          "MiniMax-2.7-HighSpeed",
          "qwen-plus"
        ],
        "label": "工作层模型"
      },
      "verify_model": {
        "type": "select",
        "default": "GLM-5.1",
        "options": [
          "GLM-5.1",
          "MiniMax-2.7-HighSpeed",
          "qwen-plus"
        ],
        "label": "核验层模型"
      },
      "max_retries": {
        "type": "number",
        "default": 7,
        "label": "最大重试"
      },
      "expandable": {
        "type": "boolean",
        "default": true,
        "label": "可展开"
      }
    }
  },
  {
    "class_type": "AgenticChain",
    "category": "Agentic",
    "display_name": "Agentic 链",
    "description": "Agentic 组合：多个 Agentic 单元串联。每步工作层输出经核验层确认后才进入下一步。可展开查看内部。",
    "color": "#4a1860",
    "inputs": [
      {
        "name": "initial_input",
        "type": "any"
      },
      {
        "name": "chain_spec",
        "type": "object"
      }
    ],
    "outputs": [
      {
        "name": "final_output",
        "type": "any"
      },
      {
        "name": "chain_report",
        "type": "object"
      }
    ],
    "params": {
      "role_declaration": {
        "type": "object",
        "label": "角色声明",
        "fields": {
          "role": {
            "type": "select",
            "options": [
              "master",
              "slave",
              "peer"
            ],
            "default": "slave",
            "label": "角色"
          },
          "responsibility": {
            "type": "text",
            "default": "",
            "label": "职责"
          },
          "constraints": {
            "type": "text",
            "default": "",
            "label": "约束"
          },
          "consumers": {
            "type": "text",
            "default": "",
            "label": "消费者"
          }
        }
      },
      "steps": {
        "type": "number",
        "default": 3,
        "label": "链长度"
      },
      "fail_strategy": {
        "type": "select",
        "default": "retry_step",
        "options": [
          "retry_step",
          "restart_chain",
          "abort"
        ],
        "label": "失败策略"
      },
      "expandable": {
        "type": "boolean",
        "default": true,
        "label": "可展开"
      }
    }
  },
  {
    "class_type": "Planner",
    "category": "Agentic",
    "display_name": "规划器",
    "description": "Agentic 组合：接收目标 → LLM 推理 → 输出工作流。可展开查看内部结构。",
    "color": "#6b21a8",
    "inputs": [
      {
        "name": "goal",
        "type": "string"
      },
      {
        "name": "constraints",
        "type": "object"
      }
    ],
    "outputs": [
      {
        "name": "workflow",
        "type": "object"
      },
      {
        "name": "reasoning",
        "type": "string"
      },
      {
        "name": "components_used",
        "type": "object"
      }
    ],
    "params": {
      "role_declaration": {
        "type": "object",
        "label": "角色声明",
        "fields": {
          "role": {
            "type": "select",
            "options": [
              "master",
              "slave",
              "peer"
            ],
            "default": "slave",
            "label": "角色"
          },
          "responsibility": {
            "type": "text",
            "default": "",
            "label": "职责"
          },
          "constraints": {
            "type": "text",
            "default": "",
            "label": "约束"
          },
          "consumers": {
            "type": "text",
            "default": "",
            "label": "消费者"
          }
        }
      },
      "goal": {
        "type": "text",
        "default": "",
        "label": "目标描述（或从输入端口接收）"
      },
      "model": {
        "type": "select",
        "default": "GLM-5.1",
        "options": [
          "GLM-5.1",
          "MiniMax-2.7-HighSpeed",
          "qwen-plus"
        ],
        "label": "推理模型"
      },
      "strategy": {
        "type": "select",
        "default": "linear",
        "options": [
          "linear",
          "parallel",
          "iterative"
        ],
        "label": "规划策略"
      },
      "max_depth": {
        "type": "number",
        "default": 5,
        "label": "逻辑链最大深度"
      },
      "reflect": {
        "type": "boolean",
        "default": true,
        "label": "启用反身性扫描"
      },
      "via_polarclaw": {
        "type": "boolean",
        "default": false,
        "label": "经 PolarClaw 规划（runPolarClaw）"
      },
      "expandable": {
        "type": "boolean",
        "default": true,
        "label": "可展开"
      }
    }
  },
