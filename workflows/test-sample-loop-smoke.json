{
  "_name": "SampleLoop Smoke",
  "_description": "StaticData → SampleLoop(N=3) 选 max_score",
  "_category": "test",

  "1": {
    "class_type": "StaticData",
    "inputs": {},
    "params": { "value": "seed-input", "label": "input" }
  },
  "2": {
    "class_type": "TextTransform",
    "inputs": { "text": ["1", 0] },
    "params": { "operation": "uppercase" }
  },
  "3": {
    "class_type": "SampleLoop",
    "inputs": {
      "sample": ["2", 0],
      "original_input": ["1", 0],
      "score": ["2", 0]
    },
    "params": { "n_samples": 3, "selection": "max_score", "_attempt": 3, "_collected_samples": ["a", "b", "c"], "_collected_scores": [1, 3, 2] }
  },
  "4": {
    "class_type": "Output",
    "inputs": { "content": ["3", 0] }
  }
}
