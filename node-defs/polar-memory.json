        "type": "boolean",
        "default": true,
        "label": "回合结束自动压缩"
      },
      "fetch_long_term": {
        "type": "boolean",
        "default": true,
        "label": "拉取 PolarMemory 长期块"
      },
      "message_role": {
        "type": "select",
        "default": "user",
        "options": [
          "user",
          "assistant",
          "system",
          "tool"
        ],
        "label": "新消息角色"
      }
    }
  },
