{
  "name": "polar-ui",
  "version": "0.1.0",
  "description": "PolarUI — Open-source ComfyUI-style workflow IDE for visual Agent orchestration (WF + LG, Claude Code parity validated)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test:agentic": "node scripts/validate-agentic-pipelines.mjs",
    "test:e2e": "node scripts/e2e-integration.mjs",
    "test:cross": "node scripts/e2e-integration.mjs && node scripts/validate-agentic-pipelines.mjs && node scripts/run-pipeline-e2e.mjs",
    "test:gate": "node scripts/run-260523-gate.mjs",
    "test:gate:260524": "node scripts/run-260524-gate.mjs",
    "test:gate:260524_1": "node scripts/run-260524_1-gate.mjs",
    "test:gate:260525": "node scripts/run-260525-gate.mjs",
    "test:gate:260526": "node scripts/run-260526-gate.mjs",
    "test:gate:260527": "node scripts/run-260527-gate.mjs",
    "test:tools-system": "npx tsx scripts/run-tools-system-matrix-smoke.mjs",
    "test:claude-code": "npx tsx scripts/run-claude-code-lg-smoke.mjs && npx tsx scripts/run-claude-code-wf-smoke.mjs",
    "test:claude-code:parity": "npx tsx scripts/run-claude-code-parity.mjs",
    "test:coverage": "ECOLOGY_COVERAGE_MIN=100 node scripts/audit-ecology-coverage.mjs",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "elkjs": "^0.9.3",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.3"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "org.polarisor.polarui",
    "productName": "PolarUI",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "directories": {
      "output": "release"
    }
  }
}
