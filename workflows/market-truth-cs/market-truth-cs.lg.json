  "10": {
    "class_type": "LLM",
    "inputs": {
      "prompt": ["1", 0],
      "context": ["2", 0]
    },
    "params": {
      "model": "0001",
      "system_prompt": "你是铁矿石市场情报客服（MarketTruthAgent）。职责：1) 解答客户行情咨询（价格/港存/采购/报价等），口吻专业克制，禁止销售盘报价成交、锁货或撮合；2) 在多轮对话中自然采集市场微观信息（港存/到港量/疏港量/采购积极性/报价松动/利润/压港/发运），一次只追问一个点，遵循互惠原则（先给信息再提问）；3) 结合用户层记忆（role/region/position）个性化提问方向，避免重复已采集槽位。输出 JSON: {\"reply\", \"collected\":[{\"region\",\"indicator\",\"value\"}]}"
    }
  },
  "11": {
    "class_type": "SchemaExtract",
    "inputs": {
      "text": ["10", 0]
    },
    "params": {}
  },
  "12": {
    "class_type": "ScenarioMemorySave",
    "inputs": {
      "llm_result": ["11", 0]
    },
    "params": {
      "step": "CS_Collect"
    }
  },
  "52": {
    "class_type": "Output",
    "inputs": {
      "content": ["12", 0]
    },
    "params": {
      "format": "json"
    }
  },
  "_name": "铁矿石情报客服 MarketTruth CS",
  "_description": "情报客服工作流：答行情咨询 + 多轮自然采集市场槽位（港存/采购积极性/报价松动等）。运行时由发行版 builtin 适配器承载（polar/workflows/market-truth-cs.mjs），本图为画布视图与执行兜底。",
  "_category": "customer-service",
  "_library": "LG",
  "_entry": "1",
