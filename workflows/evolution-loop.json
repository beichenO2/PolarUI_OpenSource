{
  "_name": "Evolution Loop",
  "_description": "自进化闭环：HistoryReader → LearningCapture → PromptEvolve → PetriDish → RecursionGuard → 自递归",
  "_category": "evolve",
  "_execution": "state_machine",
  "_start": "1",
  "_max_iterations": 50,

  "_edges": [
    { "from": "1", "to": "2" },
    { "from": "2", "to": "3" },
    { "from": "3", "to": "4" },
    { "from": "4", "to": "5" },
    { "from": "5", "to": "6" },
    { "from": "6", "to": "7" },
    { "from": "7", "to": "8", "condition": "outputs.pass_value !== null && outputs.pass_value !== undefined" },
    { "from": "7", "to": "9", "condition": "outputs.pass_value === null || outputs.pass_value === undefined" },
    { "from": "8", "to": "2", "condition": "outputs.applied === true" },
    { "from": "8", "to": "9", "condition": "outputs.applied === false || outputs.applied === undefined" }
  ],

  "1": {
    "class_type": "PromptInput",
    "inputs": {
      "expected_output": { "body": ".*" },
      "purpose": "Evolution Loop — 自进化 Cron 工作流"
    },
    "params": {
      "content": "evolution-trigger",
      "purpose": "消费 SkillCapture suggestions，蒸馏 prior_knowledge，结构进化"
    }
  },
  "2": {
    "class_type": "HistoryReader",
    "inputs": {
      "query": ["1", 0],
      "trigger": ["8", 0]
    },
    "params": {
      "limit": 5,
      "runs_dir": "PolarUI/runs/"
    }
  },
  "3": {
    "class_type": "LearningCapture",
    "inputs": {
      "execution_record": ["2", 0]
    },
    "params": {
      "fallback_path": "PolarClaw/.data/learning-captures.jsonl",
      "wake_self_learning": true
    }
  },
  "4": {
    "class_type": "ExperienceCapture",
    "inputs": {
      "capture_context": ["3", 2]
    },
    "params": {
      "capture_mode": "both",
      "storage_path": "knowledge/",
      "auto_apply": true
    }
  },
  "5": {
    "class_type": "PromptEvolve",
    "inputs": {
      "evolution_sources": ["4", 0]
    },
    "params": {
      "target": "both",
      "memory_key": "evolution-loop",
      "max_chars": 2000,
      "read_auto_apply": true,
      "include_history": true
    }
  },
  "6": {
    "class_type": "MemoryStore",
    "inputs": {
      "key": "evolution-loop",
      "content": ["5", 0]
    },
    "params": {
      "operation": "write"
    }
  },
  "7": {
    "class_type": "RecursionGuard",
    "inputs": {
      "value": ["5", 0],
      "trigger": ["6", 0]
    },
    "params": {
      "max_depth": 10,
      "cooldown_ms": 30000,
      "circuit_breaker_threshold": 3,
      "circuit_breaker_window_ms": 300000,
      "workflow_key": "evolution-loop"
    }
  },
  "8": {
    "class_type": "PetriDish",
    "inputs": {
      "seed": ["5", 1],
      "evolution_signal": ["7", 0]
    },
    "params": {
      "slave_workflow": "",
      "allow_graph_edit": true
    }
  },
  "9": {
    "class_type": "Output",
    "inputs": {
      "content": ["5", 0],
      "trigger": ["7", 0]
    },
    "params": {
      "format": "markdown"
    }
  }
}
