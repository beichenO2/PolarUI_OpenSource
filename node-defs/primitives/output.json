      "output_description": {
        "type": "text",
        "default": "",
        "label": "交付物说明（期望输出什么）"
      },
      "merge_strategy": {
        "type": "select",
        "default": "last",
        "options": [
          "concat",
          "first",
          "last",
          "json_merge"
        ],
        "label": "多 Output 合并策略"
      }
