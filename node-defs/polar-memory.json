      {
        "name": "new_message",
        "type": "string",
        "optional": true,
        "description": "工作记忆 · 输入「new_message」（类型 string），可选"
      },
      {
        "name": "user_id",
        "type": "string",
        "optional": true,
        "description": "工作记忆 · 输入「user_id」（类型 string），可选"
      }
    ],
    "outputs": [
      {
        "name": "context",
        "type": "string",
        "description": "可选上下文（记忆块、RAG、前置节点输出等）。"
      },
      {
        "name": "compressed",
        "type": "boolean",
        "description": "工作记忆 · 输出「compressed」（类型 boolean）"
      },
