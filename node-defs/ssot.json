[
  {
    "class_type": "SSoT_Project",
    "category": "SSoT/项目",
    "display_name": "项目",
    "description": "表示一个 Polarisor 子项目（polaris.json 根）",
    "color": "#1565c0",
    "inputs": [],
    "outputs": [
      {
        "name": "requirements",
        "type": "object",
        "description": "项目 · 输出「requirements」（类型 object）"
      },
      {
        "name": "status",
        "type": "string",
        "description": "项目 · 输出「status」（类型 string）"
      }
    ],
    "params": {
      "name": {
        "type": "string",
        "default": "",
        "label": "项目名"
      },
      "tier": {
        "type": "select",
        "default": "app",
        "options": [
          "infra",
          "knowledge",
          "app",
          "domain",
          "lib",
          "service",
          "meta",
          "memory"
        ],
        "label": "层级"
      },
      "status": {
        "type": "select",
        "default": "active",
        "options": [
          "active",
          "planning",
          "archived"
        ],
        "label": "状态"
      }
    }
  },
  {
    "class_type": "SSoT_Requirement",
    "category": "SSoT/需求",
    "display_name": "需求",
    "description": "一条需求（对应 polaris.json 中的 requirements[].need）",
    "color": "#2e7d32",
    "inputs": [
      {
        "name": "project",
        "type": "object",
        "description": "需求 · 输入「project」（类型 object）"
      }
    ],
    "outputs": [
      {
        "name": "features",
        "type": "object",
        "description": "需求 · 输出「features」（类型 object）"
      },
      {
        "name": "blockers",
        "type": "object",
        "description": "需求 · 输出「blockers」（类型 object）"
      }
    ],
    "params": {
      "id": {
        "type": "string",
        "default": "R1",
        "label": "ID"
      },
      "need": {
        "type": "text",
        "default": "",
        "label": "需求描述"
      },
      "approach": {
        "type": "text",
        "default": "",
        "label": "实现方案"
      }
    }
  },
  {
    "class_type": "SSoT_Feature",
    "category": "SSoT/功能",
    "display_name": "功能",
    "description": "一个具体功能（对应 features[].name）",
    "color": "#e65100",
    "inputs": [
      {
        "name": "requirement",
        "type": "object",
        "description": "功能 · 输入「requirement」（类型 object）"
      }
    ],
    "outputs": [
      {
        "name": "status",
        "type": "string",
        "description": "功能 · 输出「status」（类型 string）"
      },
      {
        "name": "interfaces",
        "type": "object",
        "description": "功能 · 输出「interfaces」（类型 object）"
      }
    ],
    "params": {
      "name": {
        "type": "string",
        "default": "",
        "label": "功能名"
      },
      "status": {
        "type": "select",
        "default": "planned",
        "options": [
          "planned",
          "in_progress",
          "done",
          "blocked"
        ],
        "label": "状态"
      },
      "test_status": {
        "type": "select",
        "default": "pending",
        "options": [
          "pending",
          "passed",
          "failed"
        ],
        "label": "测试状态"
      }
    }
  },
  {
    "class_type": "SSoT_Blocker",
    "category": "SSoT/阻塞",
    "display_name": "阻塞项",
    "description": "当前阻塞事项",
    "color": "#5a2020",
    "inputs": [
      {
        "name": "requirement",
        "type": "object",
        "description": "阻塞项 · 输入「requirement」（类型 object）"
      }
    ],
    "outputs": [],
    "params": {
      "description": {
        "type": "text",
        "default": "",
        "label": "描述"
      },
      "severity": {
        "type": "select",
        "default": "medium",
        "options": [
          "low",
          "medium",
          "high",
          "critical"
        ],
        "label": "严重度"
      }
    }
  },
  {
    "class_type": "SSoT_Dependency",
    "category": "SSoT/依赖",
    "display_name": "依赖关系",
    "description": "功能间的依赖关系",
    "color": "#4a3a5a",
    "inputs": [
      {
        "name": "from",
        "type": "object",
        "description": "依赖关系 · 输入「from」（类型 object）"
      }
    ],
    "outputs": [
      {
        "name": "to",
        "type": "object",
        "description": "依赖关系 · 输出「to」（类型 object）"
      }
    ],
    "params": {
      "dep_type": {
        "type": "select",
        "default": "requires",
        "options": [
          "requires",
          "extends",
          "replaces",
          "conflicts"
        ],
        "label": "类型"
      }
    }
  },
  {
    "class_type": "SSoT_Annotation",
    "category": "SSoT/批注",
    "display_name": "批注",
    "description": "对需求/功能的批注标记",
    "color": "#5a4a20",
    "inputs": [
      {
        "name": "target",
        "type": "object",
        "description": "批注 · 输入「target」（类型 object）"
      }
    ],
    "outputs": [],
    "params": {
      "text": {
        "type": "text",
        "default": "",
        "label": "批注内容"
      },
      "author": {
        "type": "string",
        "default": "",
        "label": "作者"
      },
      "priority": {
        "type": "select",
        "default": "normal",
        "options": [
          "low",
          "normal",
          "high",
          "urgent"
        ],
        "label": "优先级"
      }
    }
  }
]
