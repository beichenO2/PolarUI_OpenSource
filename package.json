{
  "name": "polar-ui",
  "version": "0.1.0",
  "description": "PolarUI — ComfyUI-style workflow editor for Polarisor Agent orchestration",
  "type": "module",
  "scripts": {
    "dev": "npm run patch:gui-overlay && npm run patch:export-web && node scripts/patch-dev-ecosystem-fetch.mjs && vite",
    "build": "vue-tsc --noEmit && vite build && npm run patch:lg-runner && npm run patch:toolcall && npm run patch:toolcall-gui && npm run patch:headless && npm run patch:gui-overlay && npm run patch:llm-proxy-qcsa && npm run patch:dev-ecosystem-fetch && npm run generate:toolcall-catalog && npm run sync:workflows",
    "patch:dev-ecosystem-fetch": "node scripts/patch-dev-ecosystem-fetch.mjs",
    "sync:workflows": "node scripts/sync-workflows.mjs",
    "generate:toolcall-catalog": "node scripts/generate-toolcall-catalog.mjs",
    "patch:toolcall-gui": "node scripts/patch-toolcall-gui.mjs",
    "test:toolcall-gui": "node lib/toolcall-gui/tool-list.test.mjs",
    "test:agentic": "node scripts/validate-agentic-pipelines.mjs",
    "test:e2e": "node scripts/e2e-integration.mjs",
    "test:cross": "node scripts/e2e-integration.mjs && node scripts/validate-agentic-pipelines.mjs && node scripts/run-pipeline-e2e.mjs",
    "test:gate": "node scripts/run-260523-gate.mjs",
    "test:gate:260524": "node scripts/run-260524-gate.mjs",
    "test:gate:260524_1": "node scripts/run-260524_1-gate.mjs",
    "test:gate:260525": "node scripts/run-260525-gate.mjs",
    "test:gate:260526": "node scripts/run-260526-gate.mjs",
    "test:gate:260527": "node scripts/run-260527-gate.mjs",
    "test:tools-system": "npx tsx scripts/run-tools-system-matrix-smoke.mjs",
    "test:toolcall-composite": "node lib/toolcall-composite.test.mjs",
    "patch:lg-runner": "node scripts/patch-lg-runner.mjs",
    "patch:toolcall": "node scripts/patch-toolcall-executor.mjs",
    "patch:headless": "node scripts/patch-headless-entry.mjs",
    "patch:gui-overlay": "node scripts/patch-gui-overlay-boot.mjs",
    "patch:export-web": "node scripts/patch-export-web-button.mjs",
    "patch:llm-proxy-qcsa": "node scripts/patch-llm-proxy-qcsa.mjs",
    "test:headless": "node --test lib/headless-engine.test.mjs",
    "test:gui-overlay": "node --test lib/gui-overlay.test.mjs lib/gui-overlay-browser.test.mjs",
    "test:preflight": "node lib/deploy-preflight-cli.mjs --workflow taoci-outreach",
    "test:web-release": "node --test scripts/export-release.test.mjs lib/memory-graph/register.test.mjs && cd ~/Desktop/Web_related/_template && npm test && npm run test:integration && npm run test:e2e",
    "export-release": "node scripts/export-release.mjs",
    "test:toolcall-graph": "node lib/toolcall-graph/register.test.mjs",
    "test:react-replay": "node --test workflows/tests/react-replay-graph.test.mjs",
    "test:coverage": "ECOLOGY_COVERAGE_MIN=100 node scripts/audit-ecology-coverage.mjs",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "elkjs": "^0.9.3",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.3"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "org.polarisor.polarui",
    "productName": "PolarUI",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "directories": {
      "output": "release"
    }
  }
}
